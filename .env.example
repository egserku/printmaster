## Local development defaults

# Admin panel password
ADMIN_PASSWORD=admin123

# Optional: Gemini API key for client-side tips/summary (Vite exposes only VITE_* vars)
VITE_GEMINI_API_KEY=

# Optional: SMTP (email sending). If not set, email step may fail but order will still be saved.
SMTP_USER=
SMTP_PASS=

# Optional: Trello (currently stubbed in code)
TRELLO_KEY=
TRELLO_TOKEN=
TRELLO_LIST_ID=

